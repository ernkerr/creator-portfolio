# ─── Required ──────────────────────────────────────────────────────────
# Edit these to rebrand your site. Copy this file to .env.local first.
NEXT_PUBLIC_SITE_URL=https://erinkerr.me
NEXT_PUBLIC_BRAND_NAME="ERIN KERR"
NEXT_PUBLIC_BRAND_TAGLINE="5+ years in content creation"
NEXT_PUBLIC_CONTACT_EMAIL=erin.kerr17@gmail.com

# ─── Featured nav link (optional) ──────────────────────────────────────
# Adds an external link to the header — like momi's "Creator Vault" slot.
# Leave blank to hide.
NEXT_PUBLIC_FEATURED_LABEL=Portfolio
NEXT_PUBLIC_FEATURED_URL=https://erinkerr.me

# ─── Socials (optional) ────────────────────────────────────────────────
# Username/handle only — URL is built in code. Leave blank to hide an icon.
# Order here matches render order in the Socials component.
NEXT_PUBLIC_INSTAGRAM=
NEXT_PUBLIC_TIKTOK=
NEXT_PUBLIC_YOUTUBE=
NEXT_PUBLIC_TWITTER=
NEXT_PUBLIC_BLUESKY=          # full handle, e.g. erin.bsky.social
NEXT_PUBLIC_LINKEDIN=
NEXT_PUBLIC_GITHUB=ernkerr

# ─── Media (optional) ──────────────────────────────────────────────────
# Public base URL for your brand videos/posters. Use Cloudflare R2 (zero
# egress): create a bucket, enable r2.dev or attach a custom domain.
# Example: https://pub-<hash>.r2.dev  or  https://media.your-domain.com
NEXT_PUBLIC_R2_BASE_URL=

# ─── Analytics (optional) ──────────────────────────────────────────────
# GA4 Measurement ID (G-XXXXXXXXXX). Leave blank to disable.
NEXT_PUBLIC_GA_ID=
